# .env

# ————————————————————————————
# Database settings
# ————————————————————————————

# Name (and relative path) of your SQLite file.
# It will live next to your code unless you specify a subfolder.

DATABASE_URL=sqlite+aiosqlite:///./shipping.db
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db
# (Optional) If you ever switch to Postgres/MySQL/etc, you can override the full URL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/shipping

# ————————————————————————————
# Application settings
# ————————————————————————————
LOG_LEVEL=INFO
# A human-friendly name (appears in docs & logs)
APP_NAME='My Shipping Service'

# Turn on debug/reload behavior in FastAPI
DEBUG=True
